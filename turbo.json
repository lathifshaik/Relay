{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "next-shop#typecheck": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "@relay/site#typecheck": {
      "dependsOn": ["^build", "build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
