{
  "name": "@relay/core",
  "version": "0.1.0",
  "description": "Relay protocol kernel — Action Graph, Validator, Sanitiser, Emitter, Token. Framework-agnostic.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "devDependencies": {
    "@relay/eslint-config": "workspace:*",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
